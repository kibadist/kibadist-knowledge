{
  "name": "kibadist-knowledge",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "turbo dev --filter=kibadist-web --filter=@kibadist/server",
    "build": "turbo build",
    "build:packages": "turbo build --filter='./packages/*'",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "biome check --write . || true",
    "check": "biome check --write . || true",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:push": "pnpm -F @kibadist/prisma db:push",
    "db:studio": "pnpm -F @kibadist/prisma studio",
    "clean": "turbo clean && rm -rf node_modules/.cache",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.2",
    "@types/node": "20.19.24",
    "husky": "^9.1.7",
    "turbo": "^2.6.0",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "@types/react": "19.1.10",
      "@types/react-dom": "19.1.7"
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "esbuild",
      "prisma",
      "unrs-resolver"
    ]
  }
}
