// Kibadist Knowledge — Prisma schema
// Generated client is emitted to ../src/generated/client and re-exported
// via the @kibadist/prisma package (see src/index.ts).

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  notes                 Note[]
  concepts              Concept[]
  articulations         Articulation[]
  links                 Link[]
  retrievalEvents       RetrievalEvent[]
  intakeQuestions       IntakeQuestion[]
  promotionDrafts       PromotionDraft[]
  sourceQuestions       SourceQuestion[]
  stateTransitions      ConceptStateTransition[]
  sessions              Session[]
  reflections           Reflection[]
  sourceChunks          SourceChunk[]
  conceptCandidates     SourceConceptCandidate[]
  graphNodePositions    GraphNodePosition[]
  livingConcepts        LivingConcept[]
  workspaces            Workspace[]
  articleLearningEvents ArticleLearningEvent[]
  transformerSources    TransformerSource[]

  @@map("user")
}

// The largest organizational container (DET-231/232): the "world" a body of
// knowledge belongs to (a career, a business, a research thread). Concepts are
// OWNED by a Workspace — it is the tenancy boundary the Domain/Track/GraphView
// layers organize within. For MVP a workspace has a single owner; multi-member
// access, permissions, and billing are modeled-but-deferred (the Decision in
// DET-241 governs whether knowledge ever crosses workspaces). A user always has
// at least one (auto-provisioned at registration; the last one can't be deleted).
model Workspace {
  id          String   @id @default(cuid())
  name        String
  description String?
  ownerUserId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner              User                 @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  concepts           Concept[]
  domains            Domain[]
  tracks             Track[]
  graphViews         GraphView[]
  transformerSources TransformerSource[]
  transformedArticles TransformedArticle[]

  @@index([ownerUserId])
  @@map("workspace")
}

// A GraphView (DET-236): a SAVED, SCOPED lens over the workspace's live
// Concept/Link data — never a snapshot. It stores only WHAT to show (a scope +
// its target id + filters) and view-level prefs (zoom, auto-layout choice); the
// nodes/edges are always resolved live at read time, and per-concept (x, y)
// positions still live in GraphNodePosition (DET-230), never here. Deleting a
// view never deletes a concept, link, or position. The scope target fields are
// plain ids (not FKs): a view that points at a deleted track/domain simply
// resolves to an empty graph rather than cascading or erroring.
model GraphView {
  id              String     @id @default(cuid())
  workspaceId     String
  name            String
  scope           GraphScope
  // The scope's target, by kind — at most one is set for a given scope.
  sourceConceptId String?
  trackId         String?
  domainId        String?
  centerConceptId String?
  // Opaque view filters (e.g. by cognitive state / certainty); stored + returned
  // verbatim. Applied client-side for now — server-side filtering is a follow-up.
  filters         Json       @default("{}")
  // View-level layout prefs only (zoom, which auto-layout). NEVER a node snapshot.
  layout          Json       @default("{}")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("graph_view")
}

// The scope of a graph view / query (DET-236). WORKSPACE is the default (today's
// whole-map behavior). MISCONCEPTION and REVIEW are defined for the data model
// but OUT OF BUILD SCOPE for the MVP (DET-231) — the resolver rejects them.
enum GraphScope {
  ARTICLE
  TRACK
  DOMAIN
  WORKSPACE
  CONCEPT_NEIGHBORHOOD
  MISCONCEPTION
  REVIEW
}

// A Domain (DET-234): a SEMANTIC REGION of a workspace ("Distributed Systems",
// "Stoicism"), NOT a folder. A concept can belong to several domains at once —
// the ConceptDomain join is the whole point: knowledge isn't trapped in one
// place. Domains may nest (a self-relation) but nesting is allowed, never
// forced. Owned by a Workspace; deleting a domain orphans its memberships
// (ConceptDomain rows) but NEVER the concepts. Purely organizational metadata:
// a domain never earns a concept, never writes an Articulation, never touches
// CognitiveState — the Proof-of-Learning gate (DET-189) is untouched.
model Domain {
  id             String   @id @default(cuid())
  workspaceId    String
  name           String
  description    String?
  // Self-relation for optional nesting (sub-domains). Null = top-level.
  parentDomainId String?
  // Optional UI accent (hex), for the graph/scope chrome.
  color          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // Deleting a parent domain un-nests its children (SetNull), never deletes them.
  parent         Domain?         @relation("DomainNesting", fields: [parentDomainId], references: [id], onDelete: SetNull)
  children       Domain[]        @relation("DomainNesting")
  conceptDomains ConceptDomain[]

  @@index([workspaceId])
  @@index([parentDomainId])
  @@map("domain")
}

// ConceptDomain (DET-234): the many-to-many membership of a Concept in a Domain.
// THIS JOIN IS THE WHOLE POINT — it's why a concept isn't trapped in one folder.
// Provenance is first-class: `createdBy` distinguishes an AI suggestion from a
// user tag, and `userValidated` flips true only when the user vouches for it.
// An AI suggestion (createdBy AI, userValidated false) is METADATA, NOT KNOWLEDGE
// — exactly like a SUGGESTED Link: a proposal the user accepts or removes. It
// never promotes a concept or writes an Articulation.
model ConceptDomain {
  conceptId     String
  domainId      String
  // The AI's confidence in a suggested membership (0..1); null for user tags.
  confidence    Float?
  // Who created this membership: USER (manual tag), AI (suggestion), or SYSTEM.
  createdBy     Generator @default(USER)
  // True once the user has vouched for this membership (always true for a manual
  // tag; flipped from false when the user accepts an AI suggestion).
  userValidated Boolean   @default(false)
  createdAt     DateTime  @default(now())

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  domain  Domain  @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@id([conceptId, domainId])
  @@index([conceptId])
  @@index([domainId])
  @@map("concept_domain")
}

// A Track (DET-235): the GOAL-DIRECTED layer and the product's primary entry
// point — "what am I trying to achieve with this knowledge" ("Understand React
// State", "Prepare for the systems interview"). Owned by a Workspace. Its power
// is per-track required depth: the SAME concept can be shallow in one track and
// deep in another (see TrackConcept.requiredDepth). A track organizes concepts;
// it never earns or promotes them — the Proof-of-Learning gate (DET-189) is
// untouched.
model Track {
  id          String      @id @default(cuid())
  workspaceId String
  name        String
  description String?
  type        TrackType
  // The user's own statement of the goal ("ship the feature", "pass the exam").
  goal        String?
  status      TrackStatus @default(ACTIVE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  trackConcepts TrackConcept[]

  @@index([workspaceId, status])
  @@map("track")
}

// TrackConcept (DET-235): a concept's membership in a track, carrying the
// track-LOCAL demand on it. The same concept in two tracks has two independent
// rows — different `requiredDepth`, `importance`, `status`, and order. Progress
// is NOT stored here: it's derived by reading `requiredDepth` against the
// concept's live `CognitiveState` (DET-194), so there is no second source of
// truth for mastery. `requiredDepth` is the track's DEMAND; it never changes the
// concept's actual state. An AI-proposed membership is createdBy AI + status
// CANDIDATE, awaiting the user's acceptance.
model TrackConcept {
  trackId       String
  conceptId     String
  // Manual ordering within the track (the user's study sequence); null = unsorted.
  orderIndex    Int?
  importance    ImportanceLevel    @default(MEDIUM)
  // How deeply THIS track needs the concept understood (RECOGNIZE→TEACH). Demand
  // only — compared against the concept's CognitiveState to derive progress.
  requiredDepth RequiredDepth      @default(EXPLAIN)
  status        TrackConceptStatus @default(CANDIDATE)
  createdBy     Generator          @default(USER)
  createdAt     DateTime           @default(now())

  track   Track   @relation(fields: [trackId], references: [id], onDelete: Cascade)
  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@id([trackId, conceptId])
  @@index([trackId])
  @@index([conceptId])
  @@index([trackId, orderIndex])
  @@map("track_concept")
}

// The kind of goal a Track serves (DET-235). Advisory metadata that shapes how
// the UI frames the track and how onboarding (DET-240) seeds it.
enum TrackType {
  LEARNING
  RESEARCH
  PROJECT
  CAREER
  COURSE
  PAPER_REVIEW
  PRODUCT_BUILDING
}

// A Track's lifecycle (DET-235): active → paused → completed → archived. Purely
// organizational; unrelated to a concept's CognitiveState.
enum TrackStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

// How much a concept matters WITHIN a track (DET-235). Track-local weighting the
// user (or AI) assigns; never a property of the concept itself.
enum ImportanceLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// The depth a track DEMANDS of a concept (DET-235), low→high. Compared against
// the concept's live CognitiveState to derive per-track progress — it never
// mutates that state. (RECOGNIZE≈PARSED, EXPLAIN≈EXPLAINED, APPLY≈RETRIEVED,
// TEACH≈DEFENDED/INTERNALIZED; the exact ladder lives in tracks/track-progress.ts.)
enum RequiredDepth {
  RECOGNIZE
  EXPLAIN
  APPLY
  TEACH
}

// A track-concept's membership status (DET-235). An AI suggestion lands as
// CANDIDATE; the user ACCEPTS it into the plan, marks it COMPLETED, or SKIPS it.
enum TrackConceptStatus {
  CANDIDATE
  ACCEPTED
  COMPLETED
  SKIPPED
}

model Note {
  id        String   @id @default(cuid())
  title     String
  body      String   @default("")
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("note")
}

// A unit of knowledge moving through the core loop: captured in the inbox,
// then articulated, then earned into the permanent layer.
model Concept {
  id                 String         @id @default(cuid())
  title              String
  // Optional one-line canonical summary of the core claim.
  summary            String?
  // Raw captured material from the low-friction inbox, before articulation.
  // Kept verbatim as the provenance/fallback/search surface even after the
  // structured `sourceDocument` is extracted (DET-210).
  sourceText         String?
  // Structured article representation extracted at capture (DET-210): an ordered
  // list of typed SourceBlocks (headings/paragraphs/lists/quotes/code/images/
  // tables) with stable block ids. The Reader (DET-209) renders this, DET-208
  // Reference Q&A cites its block ids, and DET-190 Compression uses it as
  // context. Shape is the SourceDocument contract in
  // server/src/source-document/source-document.types.ts. Null for items captured
  // before DET-210 (the Reader falls back to `sourceText`).
  sourceDocument     Json?
  // How the raw material entered the inbox (null for items created before the
  // capture inbox existed). Drives the inbox's "source" badge.
  captureSource      CaptureSource?
  // Origin URL when captured from a link. Provenance that survives promotion
  // (feeds the attribution work in DET-199).
  sourceUrl          String?
  status             ConceptStatus  @default(INBOX)
  // The cognitive state machine (DET-194). ALWAYS set — every concept has a
  // state, never empty. A fresh capture is SEEN; the interrogator advances it to
  // PARSED; promotion lands it at EXPLAINED or LINKED; sessions/decay/contradiction
  // drive the rest. Every change is recorded in `stateTransitions`. This is the
  // substrate the retrieval scheduler, decay, journal eligibility, and adaptive
  // friction read from. Allowed-transition rules live in
  // server/src/concept-state/transitions.ts.
  cognitiveState     CognitiveState @default(SEEN)
  // Which proof-of-learning gate mode earned this concept (provenance). Null
  // until promoted.
  gateMode           GateMode?
  // Spaced-retrieval schedule (DET-192), SM-2 style. nextReviewAt = when the
  // concept is next due (null = not yet scheduled). reviewEase is the SM-2
  // easiness factor (≥1.3), reviewIntervalDays the current gap, reviewReps the
  // count of consecutive successful recalls. A failed recall resets reps and
  // pulls the next review sooner; success drifts it further out. The schedule is
  // driven by recall success, never by frequency or streaks (anti-gamification).
  nextReviewAt       DateTime?
  reviewEase         Float          @default(2.5)
  reviewIntervalDays Int            @default(0)
  reviewReps         Int            @default(0)
  // Set by a "challenge me on this next time" reflection (DET-196); makes the
  // concept Tutor-eligible (DET-193) until a Tutor response clears it.
  tutorRequested     Boolean        @default(false)
  // Memory decay (DET-195): `activation` is the concept's prominence at the
  // moment `activationAt` was stamped; its CURRENT value decays exponentially
  // with elapsed time (computed lazily, no cron — see server/src/decay/decay.ts).
  // Retrieval, a new incoming link, a session review, or a Tutor defense refresh
  // it to 1.0. Below a threshold the concept fades; lower still it goes DORMANT.
  activation         Float          @default(1)
  activationAt       DateTime       @default(now())
  // How sure the user is of this concept (DET-199). Understanding includes
  // knowing what you DON'T fully trust, so uncertainty is expressible rather
  // than flattened — the user can mark a concept TENTATIVE or UNCERTAIN instead
  // of asserting everything as settled fact. Defaults to ASSERTED.
  certainty          Certainty      @default(ASSERTED)
  userId             String
  // The Workspace that OWNS this concept (DET-232). A concept lives in exactly
  // one workspace (the tenancy boundary); Domains/Tracks organize it via join
  // tables, never by re-parenting it. For MVP ownerUserId == the workspace owner,
  // so userId is retained for the per-id ownership checks the app already does.
  workspaceId        String
  // Track-first onboarding (DET-240): the Track a captured item was routed into,
  // set at capture time. It's an INTENT marker, not a membership — when this
  // concept is earned through the gate, promotion enrolls it into the track as an
  // AI-proposed CANDIDATE (TrackConcept). A plain id (not an FK): if the track is
  // deleted, enrollment simply finds nothing and skips. Null for normal captures.
  targetTrackId      String?
  // Inbox snooze (DET-241): hide a captured item from the inbox until this
  // moment, then let it resurface. Null = visible now. Only meaningful while
  // status is INBOX; promotion/discard make it moot. The list query treats
  // null-or-past as visible, so snoozes "expire" lazily without a cron.
  snoozedUntil       DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace         Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  articulations     Articulation[]
  outgoingLinks     Link[]                   @relation("LinkSource")
  incomingLinks     Link[]                   @relation("LinkTarget")
  retrievalEvents   RetrievalEvent[]
  intakeQuestions   IntakeQuestion[]
  promotionDraft    PromotionDraft?
  sourceQuestions   SourceQuestion[]
  stateTransitions  ConceptStateTransition[]
  sessionItems      SessionItem[]
  reflections       Reflection[]
  sourceChunks      SourceChunk[]
  conceptCandidates SourceConceptCandidate[]
  graphPosition     GraphNodePosition?
  livingConcept     LivingConcept?
  conceptDomains    ConceptDomain[]
  trackConcepts     TrackConcept[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, nextReviewAt])
  @@index([userId, cognitiveState])
  // Workspace-leading composites (DET-232): the hot read is now "concepts in
  // this workspace", optionally filtered by status/state/due. The [userId, *]
  // composites above are kept for the per-user paths that aren't workspace-scoped
  // yet (e.g. retrieval due-sweeps).
  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([workspaceId, nextReviewAt])
  @@index([workspaceId, cognitiveState])
  // The inbox read filters INBOX items by snooze visibility (DET-241).
  @@index([workspaceId, status, snoozedUntil])
  @@map("concept")
}

// The Compression step: the user's own-words explanation of a concept.
// A concept accrues many articulations over time, tracking improving clarity.
model Articulation {
  id        String                       @id @default(cuid())
  conceptId String
  userId    String
  body      String
  // Semantic embedding of `body` (OpenAI text-embedding-3-small = 1536 dims).
  // Unsupported: written/queried via raw SQL; the HNSW cosine index lives in
  // the migration. Null until the embed-on-write path populates it.
  //
  // ⚠️ MIGRATION LANDMINE: the HNSW index (articulation_embedding_hnsw_idx) is
  // hand-written raw SQL because Prisma can't express vector operator classes.
  // Prisma therefore sees it as drift and EVERY `migrate dev` adds a
  // `DROP INDEX "articulation_embedding_hnsw_idx"` to the generated migration.
  // Always delete that line from new migrations (and recreate the index if a
  // run already dropped it) — otherwise semantic search silently degrades.
  embedding Unsupported("vector(1536)")?
  createdAt DateTime                     @default(now())
  updatedAt DateTime                     @updatedAt

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conceptId])
  @@index([userId])
  @@map("articulation")
}

// The Connection step: a directed concept-to-concept edge stored in Postgres
// (no separate graph DB). Surfaced by the system, then validated by the user.
model Link {
  id              String        @id @default(cuid())
  sourceConceptId String
  targetConceptId String
  userId          String
  // Optional free-text relationship label (e.g. the user's own phrasing).
  relation        String?
  // The typed relationship the Connector (DET-191) proposed or the user chose:
  // analogy, contradiction, supports, depends-on, refines, redundant. Null for
  // pre-DET-191 links. CONTRADICTION/REDUNDANT are rendered distinctly and a
  // confirmed CONTRADICTION drives the target to CONTESTED (DET-194).
  relationKind    LinkRelation?
  // One-sentence Connector rationale citing both compressions. AI-authored
  // metadata that explains the proposal — never knowledge, never an articulation.
  rationale       String?
  // Who proposed this edge: the Connector (AI) or the user. SUGGESTED + AI = a
  // pending proposal; a manual user link is created CONFIRMED + USER.
  proposedBy      QuestionActor @default(USER)
  status          LinkStatus    @default(SUGGESTED)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  sourceConcept Concept @relation("LinkSource", fields: [sourceConceptId], references: [id], onDelete: Cascade)
  targetConcept Concept @relation("LinkTarget", fields: [targetConceptId], references: [id], onDelete: Cascade)
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sourceConceptId, targetConceptId])
  @@index([sourceConceptId])
  @@index([targetConceptId])
  @@index([userId])
  @@map("link")
}

// The Retrieval/Reflection step: one spaced-resurfacing attempt — the question
// posed, the user's recalled response, and a self/AI grade of the recall.
model RetrievalEvent {
  id        String   @id @default(cuid())
  conceptId String
  userId    String
  question  String?
  response  String?
  // Recall grade, e.g. 0-5 (SM-2 style); null until evaluated.
  score     Int?
  createdAt DateTime @default(now())

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conceptId])
  @@index([userId])
  @@index([conceptId, createdAt])
  @@map("retrieval_event")
}

// The AI Intake Interrogator (DET-188): one probing question posed while the
// user processes an inbox item. `prompt` is AI-authored metadata; `answer` is
// the user's OWN words — the canonical input. The AI never writes `answer`, and
// its text never becomes a concept's note.
model IntakeQuestion {
  id        String   @id @default(cuid())
  conceptId String
  userId    String
  // The AI-generated question (metadata, never the saved note).
  prompt    String
  // Category of probe: central_claim | terminology | assumption | ambiguity |
  // sharpen | connection. Advisory metadata for the UI.
  kind      String?
  // The user's own-words answer; null until they respond.
  answer    String?
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conceptId])
  @@index([userId])
  @@map("intake_question")
}

// The Proof-of-Learning Gate's staging area (DET-189). While a user works an
// inbox item toward promotion, their inputs live here — NOT as real
// Articulation/Link/RetrievalEvent rows, which would violate the DET-187
// invariant that inbox concepts carry no knowledge artifacts. The real rows are
// written only inside the commit transaction, as the concept flips to PERMANENT.
// One draft per inbox concept; deleted on commit or abandon.
//
// `retrieval*` is the one server-authoritative gate: the client cannot
// self-certify a passing recall, so the generated question, the user's response,
// and the AI grade are persisted here and re-checked at commit.
model PromotionDraft {
  id                  String        @id @default(cuid())
  conceptId           String        @unique
  userId              String
  // DERIVED / WRITE-ONLY (DET-197): the retrieval-pass tier is now derived from
  // `frictionLevel` via modeForLevel() everywhere it's needed; this column is
  // kept only so writes stay consistent and is NEVER read for gate decisions.
  // Do not branch on it — read `frictionLevel` instead.
  mode                GateMode      @default(QUICK)
  // Adaptive Friction (DET-197): how much proof this item must earn, scaled to
  // its cognitive weight. The system proposes a level (novelty + importance);
  // the user may escalate/de-escalate. The level decides WHICH gates are
  // required — see server/src/promotion/friction.ts. `mode` is derived from it
  // for the retrieval pass threshold (DEEP/RIGOROUS demand the higher bar).
  frictionLevel       FrictionLevel @default(DEEP)
  // Gate 1 (Articulate): the user's own-words core claim, canonical-to-be.
  articulation        String?
  // Gate 4 (Validate): set true once the user has been shown the AI-proposed
  // connections and explicitly acknowledged reviewing them. Server-recorded so
  // the gate can't be self-certified by a client (the commit re-checks it).
  connectionsReviewed Boolean       @default(false)
  // Gate 3 (Retrieve): server-generated question + the user's graded recall.
  retrievalQuestion   String?
  retrievalResponse   String?
  retrievalScore      Int?
  retrievalPassed     Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("promotion_draft")
}

// Reference Q&A (DET-208). A separate cognitive layer from earned knowledge: a
// question asked while READING a source, optionally answered by the AI as a
// source-grounded SCAFFOLD to aid comprehension. This is deliberately NOT an
// Articulation — scaffold is borrowed understanding, not earned cognition. The
// Proof-of-Learning Gate (DET-189) never reads from here: there is no code path
// that turns a REFERENCE_SCAFFOLD answer into a canonical Articulation. The
// provenance fields (askedBy/answeredBy/answerKind) make that boundary a
// queryable fact, not just a UI label, and `answerKind` keeps scaffold
// structurally distinct from any user-authored attempt.
//
// Lives against the INBOX concept being read; feeds forward as read-only context
// to the Interrogator (DET-188) and Compression (DET-190), which may DISPLAY it
// but must never prefill or write the user's canonical articulation from it.
model SourceQuestion {
  id           String         @id @default(cuid())
  conceptId    String
  userId       String
  // Who posed the question. Today always USER (the reader asks); modeled
  // explicitly so the Interrogator can also persist AI-asked follow-ups later.
  askedBy      QuestionActor  @default(USER)
  questionText String
  // The answer, null until answered. For a reference answer this is AI-authored
  // scaffold; it is never promoted to knowledge.
  answerText   String?
  answeredBy   QuestionActor?
  // Provenance of the answer text. REFERENCE_SCAFFOLD = AI comprehension aid
  // (never knowledge). USER_ATTEMPT / VALIDATED_ARTICULATION are reserved for
  // user-authored cognition so the gate can tell borrowed from earned text.
  answerKind   AnswerKind?
  // Source ranges / citation metadata grounding a reference answer (jsonb).
  citations    Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conceptId])
  @@index([userId])
  @@index([conceptId, createdAt])
  @@map("source_question")
}

// An append-only log of cognitive-state changes for a concept (DET-194). Every
// transition is recorded with its trigger and timestamp, so the concept view can
// show how understanding evolved and downstream systems can reason over history
// (e.g. "sustained retrieval success" needs the sequence, not just the latest
// state). `from` is null only for the very first transition (capture → SEEN).
model ConceptStateTransition {
  id        String          @id @default(cuid())
  conceptId String
  userId    String
  from      CognitiveState?
  to        CognitiveState
  trigger   StateTrigger
  // Optional human-readable detail (e.g. the retrieval score, the contradicting
  // concept). Never AI-authored knowledge — purely operational metadata.
  note      String?
  createdAt DateTime        @default(now())

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conceptId, createdAt])
  @@index([userId])
  @@map("concept_state_transition")
}

// An Understanding Session (DET-198): the daily 5–15 min cognitive loop. A
// session snapshots a small queue of concepts to resurface, records the user's
// progress through them (so a partial session can resume and still counts), and
// — later — its closing Reflection (DET-196). The per-concept retrieval outcome
// is recorded on the RetrievalEvent by the retrieval engine; SessionItem tracks
// the queue order, why each concept surfaced, and whether it was reached.
model Session {
  id            String        @id @default(cuid())
  userId        String
  startedAt     DateTime      @default(now())
  endedAt       DateTime?
  // The user's target length; concept-count is derived from it (DET-198).
  targetMinutes Int           @default(10)
  status        SessionStatus @default(ACTIVE)

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       SessionItem[]
  reflections Reflection[]

  @@index([userId, startedAt])
  @@index([userId, status])
  @@map("session")
}

// A closing-reflection answer for a session (DET-196): the user notices what
// MOVED in their understanding, and each answer feeds a concrete downstream
// effect — CLEARER promotes the concept's state, LESS_CLEAR pulls its next
// review sooner, CONNECTED triggers Connector candidates, CHALLENGE_NEXT flags
// it for the Tutor. Reflections are reviewable on a concept's history view.
model Reflection {
  id        String         @id @default(cuid())
  sessionId String
  userId    String
  conceptId String
  kind      ReflectionKind
  note      String?
  createdAt DateTime       @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@index([conceptId, createdAt])
  @@index([sessionId])
  @@map("reflection")
}

// What MOVED in the user's understanding this session (DET-196). Each kind maps
// to a downstream effect (see Reflection).
enum ReflectionKind {
  CLEARER
  LESS_CLEAR
  CONNECTED
  CHALLENGE_NEXT
}

// One concept in a session's queue (DET-198), in presentation order, with why it
// surfaced and the recall grade once reviewed (null until reached — partial
// sessions leave a tail unreviewed).
model SessionItem {
  id          String            @id @default(cuid())
  sessionId   String
  conceptId   String
  position    Int
  reason      SessionItemReason @default(DUE)
  reviewedAt  DateTime?
  recallScore Int?

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@index([sessionId, position])
  @@map("session_item")
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

// Why a concept surfaced in a session (DET-198): a normal due review, a
// priority contested concept, an occasional dormant "rediscovery", or an
// empty-state Tutor challenge on a mastered concept.
enum SessionItemReason {
  DUE
  CONTESTED
  REDISCOVERY
  CHALLENGE
}

// How sure the user is of a concept (DET-199). Lets uncertainty be expressed
// rather than flattened to implied certainty — the user owns the epistemic
// status of their own knowledge.
enum Certainty {
  ASSERTED
  TENTATIVE
  UNCERTAIN
}

// Semantic chunk of a captured article (DET-211). A structured SourceDocument
// (DET-210) is divided into coherent, classified sections so the article becomes
// LEARNABLE, not just readable. Lives against the INBOX concept that owns the
// source. SCAFFOLD/source object — NEVER earned knowledge; promotion through the
// Proof-of-Learning gate (DET-189) is the only path to a canonical Concept.
model SourceChunk {
  id         String          @id @default(cuid())
  conceptId  String
  userId     String
  title      String?
  // Optional AI scaffold summary — comprehension aid, never canonical knowledge.
  summary    String?
  blockIds   String[]
  kind       ChunkKind       @default(OTHER)
  importance ChunkImportance @default(SUPPORTING)
  position   Int
  createdAt  DateTime        @default(now())

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conceptId, position])
  @@index([userId])
  @@map("source_chunk")
}

// A candidate concept extracted from a captured article (DET-211). HARD BOUNDARY:
// a candidate is a source/scaffold object, NOT an earned Concept. It never enters
// the permanent graph automatically — only the user articulating + connecting +
// retrieving + validating through the gate (DET-189) promotes it. `definition` is
// source-grounded scaffold, shown as context but never prefilling the user's
// canonical articulation (DET-190).
model SourceConceptCandidate {
  id              String                   @id @default(cuid())
  conceptId       String
  userId          String
  chunkId         String?
  label           String
  definition      String?
  aliases         String[]
  sourceBlockIds  String[]
  kind            CandidateKind            @default(CONCEPT)
  importance      CandidateImportance      @default(SUPPORTING)
  generatedBy     Generator                @default(AI)
  promotionStatus CandidatePromotionStatus @default(CANDIDATE)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conceptId])
  @@index([userId])
  @@index([conceptId, promotionStatus])
  @@map("source_concept_candidate")
}

enum ChunkKind {
  MAIN_IDEA
  DEFINITION
  EXAMPLE
  APPLICATION
  HISTORY
  REFERENCE
  NOISE
  OTHER
}

enum ChunkImportance {
  CORE
  SUPPORTING
  PERIPHERAL
}

enum CandidateKind {
  CONCEPT
  TERM
  PERSON
  METHOD
  FORMULA
  THEOREM
  APPLICATION
}

enum CandidateImportance {
  CORE
  SUPPORTING
  PREREQUISITE
  PERIPHERAL
}

// Who produced a chunk/candidate (DET-211). Deterministic segmentation = SYSTEM;
// AI extraction = AI; a user-added candidate = USER.
enum Generator {
  SYSTEM
  AI
  USER
}

// Lifecycle of a candidate concept (DET-211). CANDIDATE until the user acts;
// DISMISSED if they reject it; PROMOTED once it has been earned through the gate.
enum CandidatePromotionStatus {
  CANDIDATE
  DISMISSED
  PROMOTED
}

enum ConceptStatus {
  INBOX
  ARTICULATED
  PERMANENT
}

// Where a captured inbox item came from. Pure provenance — capture never infers
// meaning from the source (no auto-tagging, no AI summary, no auto-linking).
enum CaptureSource {
  PASTE
  URL
  PDF
}

enum LinkStatus {
  SUGGESTED
  CONFIRMED
  REJECTED
}

// The typed relationship the Connector (DET-191) attributes to a candidate edge.
// CONTRADICTION and REDUNDANT are treated specially: a confirmed contradiction
// moves the target concept to CONTESTED (DET-194), and redundancy offers a merge.
enum LinkRelation {
  ANALOGY
  CONTRADICTION
  SUPPORTS
  DEPENDS_ON
  REFINES
  REDUNDANT
}

// Proof-of-learning gate depth (DET-189). QUICK = routine notes; DEEP = new
// concepts in core domains (requires a real connection + a higher recall bar).
enum GateMode {
  QUICK
  DEEP
}

// Adaptive Friction level (DET-197): how much proof an item must earn before it
// becomes knowledge, scaled to its cognitive weight rather than applied
// uniformly. Drives which Proof-of-Learning gates are required:
//   MINIMAL  — compression only
//   LIGHT    — compression + one connection
//   DEEP     — the full gate (articulate + connect + retrieve + validate)
//   RIGOROUS — DEEP, plus a mandatory post-promotion Tutor pass + contradiction
//              review (a publication-grade claim)
// The system proposes a level; the user can escalate or de-escalate, but the
// system never silently downgrades a Deep concept.
enum FrictionLevel {
  MINIMAL
  LIGHT
  DEEP
  RIGOROUS
}

// The cognitive state machine (DET-194). Every concept lives in exactly one
// state; the value is always set by a rule, never left empty. Forward moves are
// driven by user actions (gates, sessions, Tutor); backward moves by time +
// retrieval history. Some states are entered only by systems built in later
// tickets — the trigger wiring lands with those tickets, but the state and its
// allowed transitions are defined here so the substrate is complete.
//   SEEN          captured, not yet processed
//   PARSED        interrogator surfaced structure, not yet articulated (DET-188)
//   EXPLAINED     user wrote a compression (DET-189/190)
//   LINKED        connected to at least one other concept (DET-189/191)
//   RETRIEVED     at least one successful retrieval (DET-192)
//   DEFENDED      survived a Tutor challenge with a strong articulation (DET-193)
//   INTERNALIZED  sustained retrieval success + connections + defended (DET-192/193)
//   DORMANT       not retrieved/connected for a long time; activation decayed (DET-195)
//   CONTESTED     an approved contradiction edge points at it; unresolved (DET-191)
//   ARCHIVED      the user explicitly retired it
enum CognitiveState {
  SEEN
  PARSED
  EXPLAINED
  LINKED
  RETRIEVED
  DEFENDED
  INTERNALIZED
  DORMANT
  CONTESTED
  ARCHIVED
}

// What caused a cognitive-state transition (DET-194). Recorded on every
// transition so the concept's history reads as a causal log, not just a
// sequence of states.
enum StateTrigger {
  CAPTURE // concept captured → SEEN
  INTAKE_PARSED // interrogator surfaced structure → PARSED
  PROMOTION // proof-of-learning gate committed → EXPLAINED/LINKED
  LINK_CONFIRMED // a connection was confirmed → LINKED
  RETRIEVAL_SUCCESS // a spaced retrieval passed → RETRIEVED
  TUTOR_DEFENDED // survived a Socratic challenge → DEFENDED
  INTERNALIZED // sustained mastery threshold reached → INTERNALIZED
  DECAYED // inactivity decayed activation → DORMANT
  REACTIVATED // a dormant concept was retrieved again
  CONTRADICTION // an approved contradiction edge → CONTESTED
  RESOLVED // a contradiction was resolved
  ARCHIVED // the user explicitly retired the concept
}

// Who produced a question or answer in Reference Q&A (DET-208). Provenance that
// keeps AI scaffold distinguishable from user cognition at the data layer.
enum QuestionActor {
  USER
  AI
}

// What a Reference Q&A answer's text IS, epistemically (DET-208).
// REFERENCE_SCAFFOLD = AI-authored comprehension aid, never promotable to
// knowledge. USER_ATTEMPT / VALIDATED_ARTICULATION are reserved for
// user-authored cognition (the gate's domain), kept here so a single column can
// distinguish borrowed scaffold from earned articulation.
enum AnswerKind {
  REFERENCE_SCAFFOLD
  USER_ATTEMPT
  VALIDATED_ARTICULATION
}

// The Concept Graph / Overview Map (DET-230): the user's manual layout of a
// concept node on the React Flow canvas. Stored SEPARATELY from the domain so
// the graph can be recomputed/relaid-out without ever destroying the user's
// hand-placed positions. There is no graph-snapshot of nodes/edges — those are
// always derived live from Concept (nodes) + Link (edges); only the (x, y)
// coordinate the user dragged a node to is persisted here.
model GraphNodePosition {
  id        String   @id @default(cuid())
  userId    String
  // One position per concept (the layout is per-user, and a concept belongs to one
  // user) — `@unique` makes Concept↔GraphNodePosition a true 1:1.
  conceptId String   @unique
  x         Float
  y         Float
  // A locked node is pinned: layout re-runs and "fit/auto-arrange" must not move it.
  locked    Boolean  @default(false)
  updatedAt DateTime @updatedAt

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("graph_node_position")
}

// A Living Concept (DET-230): a lightweight AI-assisted persona/mental-model
// scaffold attached to an ALREADY-EARNED concept. It is created from the graph
// when the user wants a memorable scaffold for a concept they already understand.
// HARD BOUNDARY: it is SCAFFOLD, not earned knowledge — it can only attach to a
// non-INBOX Concept (the concept itself earned its place through the
// Proof-of-Learning gate), it is born DRAFT + createdBy AI, and its persona text
// never becomes an Articulation or the concept's canonical summary. The user
// validates it (DRAFT → USER_VALIDATED) or archives it; nothing here mints
// permanent knowledge.
model LivingConcept {
  id             String              @id @default(cuid())
  conceptId      String              @unique
  userId         String
  // The persona's name/handle (AI-seeded, user-editable). Metadata, not knowledge.
  personaName    String
  // One-paragraph persona summary: how this concept "introduces itself".
  personaSummary String
  // Optional persona voice/tone descriptor.
  voice          String?
  // Optional core metaphor the persona leans on, and where that metaphor BREAKS
  // (kept explicit so the scaffold never hardens a misleading analogy into fact).
  coreMetaphor   String?
  metaphorBreaks String?
  status         LivingConceptStatus @default(DRAFT)
  // Provenance: AI-seeded by default; USER if hand-authored. Never SYSTEM here.
  createdBy      Generator           @default(AI)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("living_concept")
}

// A Living Concept's lifecycle (DET-230). Born DRAFT (AI scaffold), promoted to
// USER_VALIDATED once the user vouches for it, or ARCHIVED when retired. This is
// NOT the cognitive-state machine — it governs the persona scaffold only.
enum LivingConceptStatus {
  DRAFT
  USER_VALIDATED
  ARCHIVED
}

// The source-of-truth log for the Generated Article Learning Modes (DET-278).
// HARD BOUNDARY: this stores USER ACTIVITY against generated articles, NOT
// concept knowledge and NOT the article JSON. A rewrite is not automatically a
// concept; a prediction may expose a misconception but does not become a note by
// itself. Downstream systems (Concept Library candidates, the Retrieval Engine)
// CONSUME selected events but never own them, and the article experience stays
// auditable even if concept extraction is never run.
//
// Events anchor to PERSISTED ids: `articleId`, plus the exact `articleVersionId`
// they were created from, plus optional `sectionId`/`blockId` (DET-278 rule #1).
// Never attach an event to an unstable array index. `userAnswer` is the
// learner's own words, stored VERBATIM; AI output lives in `aiFeedback` as
// STRUCTURED JSON (never only prose); per-mode extras (peek_count, focus
// duration, revision history, compared-block snapshots) live in `metadata`.
//
// The TS contract in server/src/article-learning/article-learning.types.ts is
// the single source of truth for the `eventType` vocabulary; contract-sync.spec
// fails if this enum drifts from it.
model ArticleLearningEvent {
  id               String                   @id @default(cuid())
  userId           String
  articleId        String
  // The exact article version the event was created from (DET-278 rule #1).
  articleVersionId String?
  sectionId        String?
  blockId          String?
  sourceSpanIds    String[]
  eventType        ArticleLearningEventType
  // AI-authored prompt/scaffold shown to the user (metadata, never the answer).
  prompt           String?
  // The learner's own words, stored verbatim; null for events with no answer.
  userAnswer       String?
  // Structured AI feedback (claims + provenance), never only prose. Null when
  // the event carries no feedback.
  aiFeedback       Json?
  // Per-mode extras: peek_count, focus duration, revision history, block snapshots.
  metadata         Json                     @default("{}")
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, articleId])
  @@index([articleId, eventType])
  @@map("article_learning_event")
}

// The closed set of recordable interactions across the learning modes (DET-278).
// MIRRORS the ArticleLearningEventType TS union member-for-member.
enum ArticleLearningEventType {
  overview_viewed
  prediction_submitted
  section_revealed
  block_rewrite_started
  block_rewrite_submitted
  rewrite_peeked
  comparison_generated
  rewrite_revised
  concept_candidate_approved
  review_prompt_approved
  review_completed
}

// Lifecycle of a review prompt derived from a learning event (DET-278 rule #4).
// MVP default is `suggested`: AI may propose review, the user validates what
// becomes scheduled. MIRRORS the ReviewPromptStatus TS union.
enum ReviewPromptStatus {
  suggested
  approved
  rejected
  scheduled
  retired
}

// How trustworthy a feedback claim is (DET-278 rule #5). Generated article prose
// and the original source are never collapsed into one truth layer. MIRRORS the
// SourceConfidence TS union.
enum SourceConfidence {
  source_supported
  article_supported_source_unavailable
  user_authored_unsourced
  unsupported_or_invented
  needs_review
}

// ============================================================================
// Source-Preserving Article Transformer (DET-247…259)
//
// A separate `/transformer` area (NOT the inbox/concepts flow): ingest pasted
// text / a URL / a PDF, extract + segment into versioned, ordered, located
// blocks, classify noise vs. signal, then (Wave B) generate a magazine-quality
// article whose every sentence is traceable to source blocks. The data model
// here encodes the core invariant: blocks referenced by an article are NEVER
// mutated — re-extraction bumps `blocksVersion` and writes a NEW block version
// (old rows retained), and each article PINS the `blocksVersion` it cites, so
// re-running extraction can never silently break an article's references.
// ============================================================================

enum TransformerSourceType {
  TEXT
  URL
  PDF
}

// The ingestion → extraction → segmentation → classification pipeline status,
// persisted per step (no job queue; the pipeline runs in-process async). READY
// is the terminal success of the M1 pipeline; EXTRACTION_FAILED / FAILED carry
// a human-readable error. Non-terminal rows orphaned by a restart are swept to
// FAILED on bootstrap (spec §Pipeline robustness).
enum TransformerSourceStatus {
  INGESTED
  EXTRACTING
  EXTRACTED
  SEGMENTED
  CLASSIFYING
  READY
  EXTRACTION_FAILED
  FAILED
}

// The structural type of a source block, mapped deterministically from the
// extracted SourceDocument (spec §Pipeline 3). UNKNOWN is the catch-all.
enum TransformerBlockType {
  HEADING
  PARAGRAPH
  LIST
  QUOTE
  TABLE
  CODE
  CAPTION
  UNKNOWN
}

// A block's editorial classification. The heuristic pre-pass + one batched LLM
// call assign these; code guards (NOT prompt trust) enforce that UNCERTAIN and
// the substance classes (MAIN_ARGUMENT/DEFINITION/EXAMPLE/EVIDENCE) are never
// removable, and that anything removable carries a noiseReason.
enum TransformerBlockClass {
  MAIN_ARGUMENT
  DEFINITION
  EXAMPLE
  EVIDENCE
  METHOD
  BACKGROUND
  SIDEBAR
  CITATION
  NAVIGATION_NOISE
  ADVERTISEMENT
  FOOTER
  DUPLICATE
  UNCERTAIN
}

// A TransformedArticle's lifecycle (Wave B). QUEUED→MODELING→PLANNING→
// GENERATING→CHECKING then FINAL (passed the fidelity gate) or BLOCKED (gate
// rejected) ; FAILED = could not produce schema-valid artifacts (loud failure).
enum TransformedArticleStatus {
  QUEUED
  MODELING
  PLANNING
  GENERATING
  CHECKING
  FINAL
  BLOCKED
  FAILED
}

// An ingested source: pasted text, a fetched URL, or an uploaded PDF. Holds the
// raw material (rawContent for text/HTML, rawFile for PDF bytes — bounded by
// MAX_PDF_BYTES), the extraction output (`extractedText`, the canonical flat
// text the blocks join to), and pipeline status/error. `blocksVersion` is
// bumped on every (re)segmentation; blocks are versioned so an article's
// references are never silently broken.
model TransformerSource {
  id              String                  @id @default(cuid())
  workspaceId     String
  userId          String
  type            TransformerSourceType
  status          TransformerSourceStatus @default(INGESTED)
  title           String?
  url             String?
  fileName        String?
  // Pasted text or fetched raw HTML. PDF bytes live in `rawFile` instead.
  rawContent      String?
  // Uploaded PDF bytes (bounded by MAX_PDF_BYTES at the controller).
  rawFile         Bytes?
  // { title?, author?, publishedDate?, pageCount?, truncated?, degraded? }
  metadata        Json?
  // Canonical flat text built by joining the final block texts with "\n\n";
  // charStart/charEnd offsets on blocks index into this string.
  extractedText   String?
  extractionError String?
  extractorVersion String?
  // Bumped on every (re)segmentation. Blocks are written with this version; old
  // versions are retained so articles that pinned them stay valid.
  blocksVersion   Int                     @default(0)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  workspace Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  blocks    TransformerSourceBlock[]
  articles  TransformedArticle[]

  @@index([workspaceId])
  @@index([userId])
  @@index([workspaceId, status])
  @@map("transformer_sources")
}

// One ordered, located, classified block of a source, at a specific
// `blocksVersion`. The (sourceId, version, orderIndex) tuple is unique: a block
// has a stable position within its version. Re-extraction creates a NEW version
// (new rows); old rows are never mutated, so an article pinning an old version
// keeps referencing exactly the blocks it cited.
model TransformerSourceBlock {
  id                   String                 @id @default(cuid())
  sourceId             String
  version              Int
  orderIndex           Int
  blockType            TransformerBlockType
  text                 String
  pageNumber           Int?
  charStart            Int?
  charEnd              Int?
  classification       TransformerBlockClass?
  classificationStatus String                 @default("pending")
  removable            Boolean                @default(false)
  noiseReason          String?

  source TransformerSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, version, orderIndex])
  @@index([sourceId, version])
  @@map("transformer_source_blocks")
}

// The generated article for a source (Wave B). Pins the `blocksVersion` it
// references so re-extraction can't break it. The JSON columns hold the
// intermediate + final artifacts (structure model, reshaping plan, article,
// fidelity/coverage reports, optional illustration/learning layers). `error`
// carries the failure/blocked reason.
model TransformedArticle {
  id              String                   @id @default(cuid())
  sourceId        String
  workspaceId     String
  // Pins which block version this article's references resolve against.
  blocksVersion   Int
  status          TransformedArticleStatus @default(QUEUED)
  structureModel  Json?
  reshapingPlan   Json?
  articleJson     Json?
  fidelityReport  Json?
  fidelityScore   Int?
  coverageReport  Json?
  illustrationPlan Json?
  learningLayer   Json?
  error           String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  source    TransformerSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  illustrationImages TransformerIllustrationImage[]

  @@index([sourceId])
  @@index([workspaceId])
  @@map("transformed_articles")
}

// A rendered illustration image (DET-261). Created only AFTER a suggestion is
// approved, from the approved suggestion's own text — never the source blocks.
// Stored as Postgres Bytes (mirrors the PDF rawFile pattern; no object store in
// repo) and served via an authenticated endpoint the frontend fetches as a blob.
// One current image per suggestion: a re-render upserts on (articleId, suggestionId).
model TransformerIllustrationImage {
  id           String            @id @default(cuid())
  articleId    String
  article      TransformedArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  suggestionId String // the illustrationPlan suggestion.id
  data         Bytes
  mediaType    String
  width        Int
  height       Int
  provider     String
  model        String
  prompt       String // the exact prompt sent (audit)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([articleId, suggestionId])
  @@map("transformer_illustration_images")
}
