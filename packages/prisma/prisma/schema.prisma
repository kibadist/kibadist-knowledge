// Kibadist Knowledge — Prisma schema
// Generated client is emitted to ../src/generated/client and re-exported
// via the @kibadist/prisma package (see src/index.ts).

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  notes           Note[]
  concepts        Concept[]
  articulations   Articulation[]
  links           Link[]
  retrievalEvents RetrievalEvent[]
  intakeQuestions IntakeQuestion[]
  promotionDrafts PromotionDraft[]
  sourceQuestions SourceQuestion[]
  stateTransitions ConceptStateTransition[]
  sessions         Session[]
  reflections      Reflection[]

  @@map("user")
}

model Note {
  id        String   @id @default(cuid())
  title     String
  body      String   @default("")
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("note")
}

// A unit of knowledge moving through the core loop: captured in the inbox,
// then articulated, then earned into the permanent layer.
model Concept {
  id           String        @id @default(cuid())
  title        String
  // Optional one-line canonical summary of the core claim.
  summary      String?
  // Raw captured material from the low-friction inbox, before articulation.
  // Kept verbatim as the provenance/fallback/search surface even after the
  // structured `sourceDocument` is extracted (DET-210).
  sourceText   String?
  // Structured article representation extracted at capture (DET-210): an ordered
  // list of typed SourceBlocks (headings/paragraphs/lists/quotes/code/images/
  // tables) with stable block ids. The Reader (DET-209) renders this, DET-208
  // Reference Q&A cites its block ids, and DET-190 Compression uses it as
  // context. Shape is the SourceDocument contract in
  // server/src/source-document/source-document.types.ts. Null for items captured
  // before DET-210 (the Reader falls back to `sourceText`).
  sourceDocument Json?
  // How the raw material entered the inbox (null for items created before the
  // capture inbox existed). Drives the inbox's "source" badge.
  captureSource CaptureSource?
  // Origin URL when captured from a link. Provenance that survives promotion
  // (feeds the attribution work in DET-199).
  sourceUrl    String?
  status       ConceptStatus @default(INBOX)
  // The cognitive state machine (DET-194). ALWAYS set — every concept has a
  // state, never empty. A fresh capture is SEEN; the interrogator advances it to
  // PARSED; promotion lands it at EXPLAINED or LINKED; sessions/decay/contradiction
  // drive the rest. Every change is recorded in `stateTransitions`. This is the
  // substrate the retrieval scheduler, decay, journal eligibility, and adaptive
  // friction read from. Allowed-transition rules live in
  // server/src/concept-state/transitions.ts.
  cognitiveState CognitiveState @default(SEEN)
  // Which proof-of-learning gate mode earned this concept (provenance). Null
  // until promoted.
  gateMode     GateMode?
  // Spaced-retrieval schedule (DET-192), SM-2 style. nextReviewAt = when the
  // concept is next due (null = not yet scheduled). reviewEase is the SM-2
  // easiness factor (≥1.3), reviewIntervalDays the current gap, reviewReps the
  // count of consecutive successful recalls. A failed recall resets reps and
  // pulls the next review sooner; success drifts it further out. The schedule is
  // driven by recall success, never by frequency or streaks (anti-gamification).
  nextReviewAt DateTime?
  reviewEase         Float    @default(2.5)
  reviewIntervalDays Int      @default(0)
  reviewReps         Int      @default(0)
  // Set by a "challenge me on this next time" reflection (DET-196); makes the
  // concept Tutor-eligible (DET-193) until a Tutor response clears it.
  tutorRequested     Boolean  @default(false)
  userId       String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  articulations   Articulation[]
  outgoingLinks   Link[]           @relation("LinkSource")
  incomingLinks   Link[]           @relation("LinkTarget")
  retrievalEvents RetrievalEvent[]
  intakeQuestions IntakeQuestion[]
  promotionDraft  PromotionDraft?
  sourceQuestions SourceQuestion[]
  stateTransitions ConceptStateTransition[]
  sessionItems    SessionItem[]
  reflections     Reflection[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, nextReviewAt])
  @@index([userId, cognitiveState])
  @@map("concept")
}

// The Compression step: the user's own-words explanation of a concept.
// A concept accrues many articulations over time, tracking improving clarity.
model Articulation {
  id        String                       @id @default(cuid())
  conceptId String
  userId    String
  body      String
  // Semantic embedding of `body` (OpenAI text-embedding-3-small = 1536 dims).
  // Unsupported: written/queried via raw SQL; the HNSW cosine index lives in
  // the migration. Null until the embed-on-write path populates it.
  //
  // ⚠️ MIGRATION LANDMINE: the HNSW index (articulation_embedding_hnsw_idx) is
  // hand-written raw SQL because Prisma can't express vector operator classes.
  // Prisma therefore sees it as drift and EVERY `migrate dev` adds a
  // `DROP INDEX "articulation_embedding_hnsw_idx"` to the generated migration.
  // Always delete that line from new migrations (and recreate the index if a
  // run already dropped it) — otherwise semantic search silently degrades.
  embedding Unsupported("vector(1536)")?
  createdAt DateTime                     @default(now())
  updatedAt DateTime                     @updatedAt

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conceptId])
  @@index([userId])
  @@map("articulation")
}

// The Connection step: a directed concept-to-concept edge stored in Postgres
// (no separate graph DB). Surfaced by the system, then validated by the user.
model Link {
  id              String     @id @default(cuid())
  sourceConceptId String
  targetConceptId String
  userId          String
  // Optional free-text relationship label (e.g. the user's own phrasing).
  relation        String?
  // The typed relationship the Connector (DET-191) proposed or the user chose:
  // analogy, contradiction, supports, depends-on, refines, redundant. Null for
  // pre-DET-191 links. CONTRADICTION/REDUNDANT are rendered distinctly and a
  // confirmed CONTRADICTION drives the target to CONTESTED (DET-194).
  relationKind    LinkRelation?
  // One-sentence Connector rationale citing both compressions. AI-authored
  // metadata that explains the proposal — never knowledge, never an articulation.
  rationale       String?
  // Who proposed this edge: the Connector (AI) or the user. SUGGESTED + AI = a
  // pending proposal; a manual user link is created CONFIRMED + USER.
  proposedBy      QuestionActor @default(USER)
  status          LinkStatus @default(SUGGESTED)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  sourceConcept Concept @relation("LinkSource", fields: [sourceConceptId], references: [id], onDelete: Cascade)
  targetConcept Concept @relation("LinkTarget", fields: [targetConceptId], references: [id], onDelete: Cascade)
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sourceConceptId, targetConceptId])
  @@index([sourceConceptId])
  @@index([targetConceptId])
  @@index([userId])
  @@map("link")
}

// The Retrieval/Reflection step: one spaced-resurfacing attempt — the question
// posed, the user's recalled response, and a self/AI grade of the recall.
model RetrievalEvent {
  id        String   @id @default(cuid())
  conceptId String
  userId    String
  question  String?
  response  String?
  // Recall grade, e.g. 0-5 (SM-2 style); null until evaluated.
  score     Int?
  createdAt DateTime @default(now())

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conceptId])
  @@index([userId])
  @@index([conceptId, createdAt])
  @@map("retrieval_event")
}

// The AI Intake Interrogator (DET-188): one probing question posed while the
// user processes an inbox item. `prompt` is AI-authored metadata; `answer` is
// the user's OWN words — the canonical input. The AI never writes `answer`, and
// its text never becomes a concept's note.
model IntakeQuestion {
  id        String   @id @default(cuid())
  conceptId String
  userId    String
  // The AI-generated question (metadata, never the saved note).
  prompt    String
  // Category of probe: central_claim | terminology | assumption | ambiguity |
  // sharpen | connection. Advisory metadata for the UI.
  kind      String?
  // The user's own-words answer; null until they respond.
  answer    String?
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conceptId])
  @@index([userId])
  @@map("intake_question")
}

// The Proof-of-Learning Gate's staging area (DET-189). While a user works an
// inbox item toward promotion, their inputs live here — NOT as real
// Articulation/Link/RetrievalEvent rows, which would violate the DET-187
// invariant that inbox concepts carry no knowledge artifacts. The real rows are
// written only inside the commit transaction, as the concept flips to PERMANENT.
// One draft per inbox concept; deleted on commit or abandon.
//
// `retrieval*` is the one server-authoritative gate: the client cannot
// self-certify a passing recall, so the generated question, the user's response,
// and the AI grade are persisted here and re-checked at commit.
model PromotionDraft {
  id                String   @id @default(cuid())
  conceptId         String   @unique
  userId            String
  mode              GateMode @default(QUICK)
  // Gate 1 (Articulate): the user's own-words core claim, canonical-to-be.
  articulation      String?
  // Gate 4 (Validate): set true once the user has been shown the AI-proposed
  // connections and explicitly acknowledged reviewing them. Server-recorded so
  // the gate can't be self-certified by a client (the commit re-checks it).
  connectionsReviewed Boolean @default(false)
  // Gate 3 (Retrieve): server-generated question + the user's graded recall.
  retrievalQuestion String?
  retrievalResponse String?
  retrievalScore    Int?
  retrievalPassed   Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("promotion_draft")
}

// Reference Q&A (DET-208). A separate cognitive layer from earned knowledge: a
// question asked while READING a source, optionally answered by the AI as a
// source-grounded SCAFFOLD to aid comprehension. This is deliberately NOT an
// Articulation — scaffold is borrowed understanding, not earned cognition. The
// Proof-of-Learning Gate (DET-189) never reads from here: there is no code path
// that turns a REFERENCE_SCAFFOLD answer into a canonical Articulation. The
// provenance fields (askedBy/answeredBy/answerKind) make that boundary a
// queryable fact, not just a UI label, and `answerKind` keeps scaffold
// structurally distinct from any user-authored attempt.
//
// Lives against the INBOX concept being read; feeds forward as read-only context
// to the Interrogator (DET-188) and Compression (DET-190), which may DISPLAY it
// but must never prefill or write the user's canonical articulation from it.
model SourceQuestion {
  id           String         @id @default(cuid())
  conceptId    String
  userId       String
  // Who posed the question. Today always USER (the reader asks); modeled
  // explicitly so the Interrogator can also persist AI-asked follow-ups later.
  askedBy      QuestionActor  @default(USER)
  questionText String
  // The answer, null until answered. For a reference answer this is AI-authored
  // scaffold; it is never promoted to knowledge.
  answerText   String?
  answeredBy   QuestionActor?
  // Provenance of the answer text. REFERENCE_SCAFFOLD = AI comprehension aid
  // (never knowledge). USER_ATTEMPT / VALIDATED_ARTICULATION are reserved for
  // user-authored cognition so the gate can tell borrowed from earned text.
  answerKind   AnswerKind?
  // Source ranges / citation metadata grounding a reference answer (jsonb).
  citations    Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conceptId])
  @@index([userId])
  @@index([conceptId, createdAt])
  @@map("source_question")
}

// An append-only log of cognitive-state changes for a concept (DET-194). Every
// transition is recorded with its trigger and timestamp, so the concept view can
// show how understanding evolved and downstream systems can reason over history
// (e.g. "sustained retrieval success" needs the sequence, not just the latest
// state). `from` is null only for the very first transition (capture → SEEN).
model ConceptStateTransition {
  id        String         @id @default(cuid())
  conceptId String
  userId    String
  from      CognitiveState?
  to        CognitiveState
  trigger   StateTrigger
  // Optional human-readable detail (e.g. the retrieval score, the contradicting
  // concept). Never AI-authored knowledge — purely operational metadata.
  note      String?
  createdAt DateTime       @default(now())

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conceptId, createdAt])
  @@index([userId])
  @@map("concept_state_transition")
}

// An Understanding Session (DET-198): the daily 5–15 min cognitive loop. A
// session snapshots a small queue of concepts to resurface, records the user's
// progress through them (so a partial session can resume and still counts), and
// — later — its closing Reflection (DET-196). The per-concept retrieval outcome
// is recorded on the RetrievalEvent by the retrieval engine; SessionItem tracks
// the queue order, why each concept surfaced, and whether it was reached.
model Session {
  id            String        @id @default(cuid())
  userId        String
  startedAt     DateTime      @default(now())
  endedAt       DateTime?
  // The user's target length; concept-count is derived from it (DET-198).
  targetMinutes Int           @default(10)
  status        SessionStatus @default(ACTIVE)

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items SessionItem[]
  reflections Reflection[]

  @@index([userId, startedAt])
  @@index([userId, status])
  @@map("session")
}

// A closing-reflection answer for a session (DET-196): the user notices what
// MOVED in their understanding, and each answer feeds a concrete downstream
// effect — CLEARER promotes the concept's state, LESS_CLEAR pulls its next
// review sooner, CONNECTED triggers Connector candidates, CHALLENGE_NEXT flags
// it for the Tutor. Reflections are reviewable on a concept's history view.
model Reflection {
  id        String         @id @default(cuid())
  sessionId String
  userId    String
  conceptId String
  kind      ReflectionKind
  note      String?
  createdAt DateTime       @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@index([conceptId, createdAt])
  @@index([sessionId])
  @@map("reflection")
}

// What MOVED in the user's understanding this session (DET-196). Each kind maps
// to a downstream effect (see Reflection).
enum ReflectionKind {
  CLEARER
  LESS_CLEAR
  CONNECTED
  CHALLENGE_NEXT
}

// One concept in a session's queue (DET-198), in presentation order, with why it
// surfaced and the recall grade once reviewed (null until reached — partial
// sessions leave a tail unreviewed).
model SessionItem {
  id          String            @id @default(cuid())
  sessionId   String
  conceptId   String
  position    Int
  reason      SessionItemReason @default(DUE)
  reviewedAt  DateTime?
  recallScore Int?

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@index([sessionId, position])
  @@map("session_item")
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

// Why a concept surfaced in a session (DET-198): a normal due review, a
// priority contested concept, an occasional dormant "rediscovery", or an
// empty-state Tutor challenge on a mastered concept.
enum SessionItemReason {
  DUE
  CONTESTED
  REDISCOVERY
  CHALLENGE
}

enum ConceptStatus {
  INBOX
  ARTICULATED
  PERMANENT
}

// Where a captured inbox item came from. Pure provenance — capture never infers
// meaning from the source (no auto-tagging, no AI summary, no auto-linking).
enum CaptureSource {
  PASTE
  URL
  PDF
}

enum LinkStatus {
  SUGGESTED
  CONFIRMED
  REJECTED
}

// The typed relationship the Connector (DET-191) attributes to a candidate edge.
// CONTRADICTION and REDUNDANT are treated specially: a confirmed contradiction
// moves the target concept to CONTESTED (DET-194), and redundancy offers a merge.
enum LinkRelation {
  ANALOGY
  CONTRADICTION
  SUPPORTS
  DEPENDS_ON
  REFINES
  REDUNDANT
}

// Proof-of-learning gate depth (DET-189). QUICK = routine notes; DEEP = new
// concepts in core domains (requires a real connection + a higher recall bar).
enum GateMode {
  QUICK
  DEEP
}

// The cognitive state machine (DET-194). Every concept lives in exactly one
// state; the value is always set by a rule, never left empty. Forward moves are
// driven by user actions (gates, sessions, Tutor); backward moves by time +
// retrieval history. Some states are entered only by systems built in later
// tickets — the trigger wiring lands with those tickets, but the state and its
// allowed transitions are defined here so the substrate is complete.
//   SEEN          captured, not yet processed
//   PARSED        interrogator surfaced structure, not yet articulated (DET-188)
//   EXPLAINED     user wrote a compression (DET-189/190)
//   LINKED        connected to at least one other concept (DET-189/191)
//   RETRIEVED     at least one successful retrieval (DET-192)
//   DEFENDED      survived a Tutor challenge with a strong articulation (DET-193)
//   INTERNALIZED  sustained retrieval success + connections + defended (DET-192/193)
//   DORMANT       not retrieved/connected for a long time; activation decayed (DET-195)
//   CONTESTED     an approved contradiction edge points at it; unresolved (DET-191)
//   ARCHIVED      the user explicitly retired it
enum CognitiveState {
  SEEN
  PARSED
  EXPLAINED
  LINKED
  RETRIEVED
  DEFENDED
  INTERNALIZED
  DORMANT
  CONTESTED
  ARCHIVED
}

// What caused a cognitive-state transition (DET-194). Recorded on every
// transition so the concept's history reads as a causal log, not just a
// sequence of states.
enum StateTrigger {
  CAPTURE           // concept captured → SEEN
  INTAKE_PARSED     // interrogator surfaced structure → PARSED
  PROMOTION         // proof-of-learning gate committed → EXPLAINED/LINKED
  LINK_CONFIRMED    // a connection was confirmed → LINKED
  RETRIEVAL_SUCCESS // a spaced retrieval passed → RETRIEVED
  TUTOR_DEFENDED    // survived a Socratic challenge → DEFENDED
  INTERNALIZED      // sustained mastery threshold reached → INTERNALIZED
  DECAYED           // inactivity decayed activation → DORMANT
  REACTIVATED       // a dormant concept was retrieved again
  CONTRADICTION     // an approved contradiction edge → CONTESTED
  RESOLVED          // a contradiction was resolved
  ARCHIVED          // the user explicitly retired the concept
}

// Who produced a question or answer in Reference Q&A (DET-208). Provenance that
// keeps AI scaffold distinguishable from user cognition at the data layer.
enum QuestionActor {
  USER
  AI
}

// What a Reference Q&A answer's text IS, epistemically (DET-208).
// REFERENCE_SCAFFOLD = AI-authored comprehension aid, never promotable to
// knowledge. USER_ATTEMPT / VALIDATED_ARTICULATION are reserved for
// user-authored cognition (the gate's domain), kept here so a single column can
// distinguish borrowed scaffold from earned articulation.
enum AnswerKind {
  REFERENCE_SCAFFOLD
  USER_ATTEMPT
  VALIDATED_ARTICULATION
}
