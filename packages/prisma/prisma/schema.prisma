// Kibadist Knowledge — Prisma schema
// Generated client is emitted to ../src/generated/client and re-exported
// via the @kibadist/prisma package (see src/index.ts).

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  notes Note[]

  @@map("user")
}

model Note {
  id        String   @id @default(cuid())
  title     String
  body      String   @default("")
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("note")
}
