// Kibadist Knowledge — Prisma schema
// Generated client is emitted to ../src/generated/client and re-exported
// via the @kibadist/prisma package (see src/index.ts).

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  notes           Note[]
  concepts        Concept[]
  articulations   Articulation[]
  links           Link[]
  retrievalEvents RetrievalEvent[]
  intakeQuestions IntakeQuestion[]
  promotionDrafts PromotionDraft[]

  @@map("user")
}

model Note {
  id        String   @id @default(cuid())
  title     String
  body      String   @default("")
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("note")
}

// A unit of knowledge moving through the core loop: captured in the inbox,
// then articulated, then earned into the permanent layer.
model Concept {
  id           String        @id @default(cuid())
  title        String
  // Optional one-line canonical summary of the core claim.
  summary      String?
  // Raw captured material from the low-friction inbox, before articulation.
  sourceText   String?
  // How the raw material entered the inbox (null for items created before the
  // capture inbox existed). Drives the inbox's "source" badge.
  captureSource CaptureSource?
  // Origin URL when captured from a link. Provenance that survives promotion
  // (feeds the attribution work in DET-199).
  sourceUrl    String?
  status       ConceptStatus @default(INBOX)
  // Cognitive state once earned (DET-189): EXPLAINED (articulated, no links) or
  // LINKED (articulated + connected). Null while still an inbox capture.
  cognitiveState CognitiveState?
  // Which proof-of-learning gate mode earned this concept (provenance). Null
  // until promoted.
  gateMode     GateMode?
  // When this concept is next due for spaced resurfacing (null = not scheduled).
  nextReviewAt DateTime?
  userId       String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  articulations   Articulation[]
  outgoingLinks   Link[]           @relation("LinkSource")
  incomingLinks   Link[]           @relation("LinkTarget")
  retrievalEvents RetrievalEvent[]
  intakeQuestions IntakeQuestion[]
  promotionDraft  PromotionDraft?

  @@index([userId])
  @@index([userId, status])
  @@index([userId, nextReviewAt])
  @@map("concept")
}

// The Compression step: the user's own-words explanation of a concept.
// A concept accrues many articulations over time, tracking improving clarity.
model Articulation {
  id        String                       @id @default(cuid())
  conceptId String
  userId    String
  body      String
  // Semantic embedding of `body` (OpenAI text-embedding-3-small = 1536 dims).
  // Unsupported: written/queried via raw SQL; the HNSW cosine index lives in
  // the migration. Null until the embed-on-write path populates it.
  //
  // ⚠️ MIGRATION LANDMINE: the HNSW index (articulation_embedding_hnsw_idx) is
  // hand-written raw SQL because Prisma can't express vector operator classes.
  // Prisma therefore sees it as drift and EVERY `migrate dev` adds a
  // `DROP INDEX "articulation_embedding_hnsw_idx"` to the generated migration.
  // Always delete that line from new migrations (and recreate the index if a
  // run already dropped it) — otherwise semantic search silently degrades.
  embedding Unsupported("vector(1536)")?
  createdAt DateTime                     @default(now())
  updatedAt DateTime                     @updatedAt

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conceptId])
  @@index([userId])
  @@map("articulation")
}

// The Connection step: a directed concept-to-concept edge stored in Postgres
// (no separate graph DB). Surfaced by the system, then validated by the user.
model Link {
  id              String     @id @default(cuid())
  sourceConceptId String
  targetConceptId String
  userId          String
  // Optional user-supplied relationship label (e.g. "supports", "contradicts").
  relation        String?
  status          LinkStatus @default(SUGGESTED)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  sourceConcept Concept @relation("LinkSource", fields: [sourceConceptId], references: [id], onDelete: Cascade)
  targetConcept Concept @relation("LinkTarget", fields: [targetConceptId], references: [id], onDelete: Cascade)
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sourceConceptId, targetConceptId])
  @@index([sourceConceptId])
  @@index([targetConceptId])
  @@index([userId])
  @@map("link")
}

// The Retrieval/Reflection step: one spaced-resurfacing attempt — the question
// posed, the user's recalled response, and a self/AI grade of the recall.
model RetrievalEvent {
  id        String   @id @default(cuid())
  conceptId String
  userId    String
  question  String?
  response  String?
  // Recall grade, e.g. 0-5 (SM-2 style); null until evaluated.
  score     Int?
  createdAt DateTime @default(now())

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conceptId])
  @@index([userId])
  @@index([conceptId, createdAt])
  @@map("retrieval_event")
}

// The AI Intake Interrogator (DET-188): one probing question posed while the
// user processes an inbox item. `prompt` is AI-authored metadata; `answer` is
// the user's OWN words — the canonical input. The AI never writes `answer`, and
// its text never becomes a concept's note.
model IntakeQuestion {
  id        String   @id @default(cuid())
  conceptId String
  userId    String
  // The AI-generated question (metadata, never the saved note).
  prompt    String
  // Category of probe: central_claim | terminology | assumption | ambiguity |
  // sharpen | connection. Advisory metadata for the UI.
  kind      String?
  // The user's own-words answer; null until they respond.
  answer    String?
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conceptId])
  @@index([userId])
  @@map("intake_question")
}

// The Proof-of-Learning Gate's staging area (DET-189). While a user works an
// inbox item toward promotion, their inputs live here — NOT as real
// Articulation/Link/RetrievalEvent rows, which would violate the DET-187
// invariant that inbox concepts carry no knowledge artifacts. The real rows are
// written only inside the commit transaction, as the concept flips to PERMANENT.
// One draft per inbox concept; deleted on commit or abandon.
//
// `retrieval*` is the one server-authoritative gate: the client cannot
// self-certify a passing recall, so the generated question, the user's response,
// and the AI grade are persisted here and re-checked at commit.
model PromotionDraft {
  id                String   @id @default(cuid())
  conceptId         String   @unique
  userId            String
  mode              GateMode @default(QUICK)
  // Gate 1 (Articulate): the user's own-words core claim, canonical-to-be.
  articulation      String?
  // Gate 4 (Validate): set true once the user has been shown the AI-proposed
  // connections and explicitly acknowledged reviewing them. Server-recorded so
  // the gate can't be self-certified by a client (the commit re-checks it).
  connectionsReviewed Boolean @default(false)
  // Gate 3 (Retrieve): server-generated question + the user's graded recall.
  retrievalQuestion String?
  retrievalResponse String?
  retrievalScore    Int?
  retrievalPassed   Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("promotion_draft")
}

enum ConceptStatus {
  INBOX
  ARTICULATED
  PERMANENT
}

// Where a captured inbox item came from. Pure provenance — capture never infers
// meaning from the source (no auto-tagging, no AI summary, no auto-linking).
enum CaptureSource {
  PASTE
  URL
  PDF
}

enum LinkStatus {
  SUGGESTED
  CONFIRMED
  REJECTED
}

// Proof-of-learning gate depth (DET-189). QUICK = routine notes; DEEP = new
// concepts in core domains (requires a real connection + a higher recall bar).
enum GateMode {
  QUICK
  DEEP
}

// A promoted concept's initial cognitive state (DET-189). EXPLAINED = articulated
// as a standalone root; LINKED = articulated and connected to the graph.
enum CognitiveState {
  EXPLAINED
  LINKED
}
