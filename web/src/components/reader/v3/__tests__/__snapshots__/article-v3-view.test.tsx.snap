                  </td>
                  <td>
                    Apply the non-linearity
                  </td>
                </tr>
                <tr>
                  <td>
                    Project
                  </td>
                  <td>
                    Project back down to the model size
                  </td>
                </tr>
              </tbody>
            </table>
          </figure>
        </button>
