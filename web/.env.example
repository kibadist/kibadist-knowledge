# Base URL of the NestJS API (includes the /api global prefix).
# Inlined into the client bundle at BUILD time (Next.js NEXT_PUBLIC_*).
# Local dev:
NEXT_PUBLIC_API_URL=http://localhost:4000/api
# Deployed (DigitalOcean): set to the API's public URL + /api, e.g.
# NEXT_PUBLIC_API_URL=https://kibadist-api-xxxxx.ondigitalocean.app/api
# In .do/app.yaml this is wired automatically as ${api.PUBLIC_URL}/api.
