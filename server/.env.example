# ============================================================
# @kibadist/server environment
# Copy to .env and fill in values: cp .env.example .env
# ============================================================

NODE_ENV=development
# Default 4000 avoids clashing with other local NestJS apps (e.g. on 8080).
PORT=4000

# --- Database (matches docker-compose.yml) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kibadist?schema=public

# --- JWT auth ---
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=dev-insecure-change-me
JWT_EXPIRES_IN=7d

# --- Frontend (CORS) ---
FRONTEND_URL=http://localhost:3000
# Optional: comma-separated allowlist; overrides FRONTEND_URL when set.
# e.g. CORS_ORIGINS=https://app.example.com,https://admin.example.com
# CORS_ORIGINS=
#
# Deployed (DigitalOcean): the platform injects DATABASE_URL (from the managed
# DB) and JWT_SECRET (a generated secret); set CORS_ORIGINS to the deployed web
# origin. In .do/app.yaml this is wired as ${web.PUBLIC_URL}. See DEPLOY.md.

# --- AI layer ---
# Active provider: "openai" (implemented) or "ollama" (seam, not yet implemented).
AI_PROVIDER=openai
# Required when AI_PROVIDER=openai. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional model overrides (sensible defaults applied when unset).
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
# Image model for rendering approved illustration suggestions (DET-261).
# OPENAI_IMAGE_MODEL=gpt-image-1

# --- Article generation router (DET-362) ---
# v3 (Source-Grounded Learning Article, DET-344) ships as a PARALLEL pipeline beside
# the frozen v2 fallback. Source-kind detection always runs and is stored on every
# article; these flags only govern ROUTING. v2 is the default for every source until
# the flags below are turned on. Truthy = 1/true/yes/on.
#
# Master gate. While off, EVERY source generates v2.
# ARTICLE_GENERATION_V3_ENABLED=false
# Per-source-kind rollout (only effective with the master gate on):
# ARTICLE_GENERATION_V3_TRANSCRIPTS_ENABLED=false
# ARTICLE_GENERATION_V3_STRUCTURED_ARTICLES_ENABLED=false
# Restrict v3 to internal-preview jobs only; live jobs stay on v2. Defaults to
# TRUE (the safest rollout) — clear it to let live jobs route to v3.
# ARTICLE_GENERATION_V3_INTERNAL_PREVIEW_ONLY=true
# Allow a FAILED v3 job to re-run on v2 (otherwise it stays FAILED). Opt-in.
# ARTICLE_GENERATION_V3_FALLBACK_TO_V2=false
#
# Legacy aliases (still recognised): TRANSFORMER_V3_ENABLED (DET-345) is an alias
# for the master gate; ARTICLE_V3_ENABLED (DET-344) gates the coarse v3 seam.
# TRANSFORMER_V3_ENABLED=false
# ARTICLE_V3_ENABLED=false

# --- Rate limiting (DET-207) ---
# Per-user throttling (default 120/min, ai 20/min) is ON whenever this is unset.
# Local-dev escape hatch ONLY: set true to bypass the limits while hand-testing
# the AI pipeline. NEVER set in production.
# THROTTLE_DISABLED=false
