# ============================================================
# @kibadist/server environment
# Copy to .env and fill in values: cp .env.example .env
# ============================================================

NODE_ENV=development
# Default 4000 avoids clashing with other local NestJS apps (e.g. on 8080).
PORT=4000

# --- Database (matches docker-compose.yml) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kibadist?schema=public

# --- JWT auth ---
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=dev-insecure-change-me
JWT_EXPIRES_IN=7d

# --- Frontend (CORS) ---
FRONTEND_URL=http://localhost:3000
# Optional: comma-separated allowlist; overrides FRONTEND_URL when set.
# e.g. CORS_ORIGINS=https://app.example.com,https://admin.example.com
# CORS_ORIGINS=
#
# Deployed (DigitalOcean): the platform injects DATABASE_URL (from the managed
# DB) and JWT_SECRET (a generated secret); set CORS_ORIGINS to the deployed web
# origin. In .do/app.yaml this is wired as ${web.PUBLIC_URL}. See DEPLOY.md.

# --- AI layer ---
# Active provider: "openai" (implemented) or "ollama" (seam, not yet implemented).
AI_PROVIDER=openai
# Required when AI_PROVIDER=openai. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional model overrides (sensible defaults applied when unset).
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
# Image model for rendering approved illustration suggestions (DET-261).
# OPENAI_IMAGE_MODEL=gpt-image-1

# --- Transformer v3 router (DET-345) ---
# Rollout control for the v3 article pipeline. Source-kind detection always runs
# and is stored on every article; this flag only governs ROUTING. When unset/off,
# every source uses the v2 pipeline (the default fallback). When on (1/true/yes/on),
# the two initially-targeted broken source kinds (transcript_lesson,
# structured_web_article) route to v3; all other kinds and `unknown` stay on v2.
# TRANSFORMER_V3_ENABLED=false
