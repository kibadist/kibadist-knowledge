# ============================================================
# @kibadist/server environment
# Copy to .env and fill in values: cp .env.example .env
# ============================================================

NODE_ENV=development
# Default 4000 avoids clashing with other local NestJS apps (e.g. on 8080).
PORT=4000

# --- Database (matches docker-compose.yml) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kibadist?schema=public

# --- JWT auth ---
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=dev-insecure-change-me
JWT_EXPIRES_IN=7d

# --- Frontend (CORS) ---
FRONTEND_URL=http://localhost:3000
# Optional: comma-separated allowlist; overrides FRONTEND_URL when set.
# e.g. CORS_ORIGINS=https://app.example.com,https://admin.example.com
# CORS_ORIGINS=
#
# Deployed (DigitalOcean): the platform injects DATABASE_URL (from the managed
# DB) and JWT_SECRET (a generated secret); set CORS_ORIGINS to the deployed web
# origin. In .do/app.yaml this is wired as ${web.PUBLIC_URL}. See DEPLOY.md.

# --- AI layer ---
# Active provider: "openai" (implemented), "fixture" (deterministic offline
# provider, DET-343), or "ollama" (seam, not yet implemented).
AI_PROVIDER=openai
# Required when AI_PROVIDER=openai. Get one at https://platform.openai.com/api-keys
# If AI_PROVIDER=openai but this is BLANK, the server auto-falls back to the
# deterministic fixture provider (DET-343) so a keyless environment still works —
# every transformer call returns source-grounded fixture content, no network.
OPENAI_API_KEY=
# Optional model overrides (sensible defaults applied when unset).
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
# Image model for rendering approved illustration suggestions (DET-261).
# OPENAI_IMAGE_MODEL=gpt-image-1

# --- v3 Source-Grounded Learning Article Engine (DET-343) ---
# Rollout for the v3 pipeline. Modes: off (default, everything runs frozen v2),
# preview (only sources tagged v3Preview run v3), source_kind (the kinds in
# TRANSFORMER_V3_KINDS run v3), on (v3 is the default for everything).
# TRANSFORMER_V3_MODE=off
# Comma list of source kinds enabled when TRANSFORMER_V3_MODE=source_kind:
# transcript,structured_article,reference,mixed
# TRANSFORMER_V3_KINDS=transcript
#
# Keyless verification recipe: leave OPENAI_API_KEY blank (fixture provider auto-
# engages) and set TRANSFORMER_V3_MODE=on, OR use the per-source "Generate v3
# learning article" button in the reader's Inspector tab (works in any mode).
